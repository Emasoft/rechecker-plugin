{
  "description": "Rechecker: automated code review after git commits, with transient error logging",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/rechecker.sh",
            "timeout": 7200
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|server_error",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/log-stop-failure.sh"
          }
        ]
      }
    ]
  }
}
