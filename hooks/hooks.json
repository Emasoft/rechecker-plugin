{
  "description": "Rechecker: error logging + subagent token tracking",
  "hooks": {
    "StopFailure": [
      {
        "matcher": "rate_limit|server_error",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/log-stop-failure.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/log-subagent-tokens.py",
            "async": true
          }
        ]
      }
    ]
  }
}
