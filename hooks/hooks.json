{
  "description": "Rechecker: automated code review after git commits",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/rechecker.sh",
            "timeout": 900
          }
        ]
      }
    ]
  }
}
