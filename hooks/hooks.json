{
  "description": "Rechecker: automated code review after git commits, with transient error logging",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/rechecker.py",
            "timeout": 86400
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|server_error",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/log-stop-failure.py"
          }
        ]
      }
    ]
  }
}
