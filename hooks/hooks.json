{
  "description": "Rechecker: automated code review after git commits, with resume support and error logging",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/rechecker.py",
            "timeout": 7200,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/resume-check.py",
            "timeout": 30
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "rate_limit|server_error",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/log-stop-failure.py"
          }
        ]
      }
    ]
  }
}
